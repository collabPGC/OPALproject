    },
    "google": {
      "enabled": true,
      "apiKey": "YOUR_GOOGLE_API_KEY",
      "models": {
        "gemini-3.1-pro-preview": {
          "tier": "premium",
          "capabilities": [
            "reasoning",
            "code",
            "vision",
            "deep_thinking",
            "long-context"
          ],
          "contextWindow": 1000000,
          "outputTokens": 65536,
