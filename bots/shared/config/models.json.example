          ],
          "contextWindow": 200000,
          "outputTokens": 128000,
          "comment": "Most intelligent model, $5/$25 per MTok"
        },
        "claude-sonnet-4-6": {
          "tier": "standard",
          "capabilities": [
            "reasoning",
            "code",
