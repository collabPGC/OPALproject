      "preferred": ["claude-sonnet-4-20250514", "gpt-5.2-instant", "gemini-3-flash"],
      "requiredCapabilities": []
    }
  },
  "defaults": {
    "taskType": "general",
    "fallbackEnabled": true,
    "retryOnFailure": true,
    "maxRetries": 2
  }
