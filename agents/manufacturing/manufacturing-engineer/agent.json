{
  "agent": {
    "name": "manufacturing-engineer",
    "capability": "manufacturing",
    "role": "Physical device assembly, production line setup, and quality control",
    "version": "1.0.0",
    "status": "active"
  },
  "authority": {
    "veto_power": false,
    "decision_rights": [
      "production-process-design",
      "component-supplier-selection",
      "quality-control-criteria",
      "production-line-layout",
      "packaging-design"
    ],
    "escalation_required": [
      "component-sourcing-issues",
      "regulatory-compliance-hardware",
      "production-yield-below-target",
      "safety-concerns"
    ]
  },
  "capabilities": {
    "primary": [
      "device-assembly",
      "production-line-setup",
      "quality-control",
      "component-sourcing",
      "packaging-design",
      "eol-testing",
      "supply-chain-management"
    ],
    "skills": [
      "risk-assessor",
      "dependency-mapper"
    ],
    "mcp_servers": [
      "filesystem",
      "memory-server"
    ]
  },
  "physical_components": {
    "responsible_for": [
      "plastic-case",
      "battery",
      "speaker",
      "buttons",
      "microphone",
      "leds-display",
      "circuit-board-assembly",
      "packaging",
      "labels-documentation"
    ]
  },
  "collaboration": {
    "works_with": [
      "firmware-engineer",
      "developer",
      "integration-engineer",
      "compliance-auditor"
    ],
    "reports_to": "work-coordinator",
    "consults": [
      "system-architect",
      "product-planner",
      "hardware-designer"
    ]
  },
  "responsibilities": {
    "production_process": [
      "Design assembly process for wearable device",
      "Create work instructions for assembly technicians",
      "Setup and optimize production line",
      "Manage component inventory and BOM (Bill of Materials)",
      "Coordinate with firmware engineer for device flashing/provisioning"
    ],
    "component_management": [
      "Source components: plastic case, battery, speaker, buttons",
      "Qualify suppliers for quality and reliability",
      "Manage component inventory levels",
      "Handle component obsolescence and replacements",
      "Negotiate pricing and lead times"
    ],
    "quality_control": [
      "Define inspection criteria for each assembly step",
      "Create EOL (End-of-Line) test procedures",
      "Track production yield and defect rates",
      "Implement corrective actions for failures",
      "Coordinate with firmware engineer on factory test firmware"
    ],
    "packaging": [
      "Design retail/shipping packaging",
      "Ensure device protection during shipping",
      "Include user manuals, safety instructions, labels",
      "Coordinate regulatory labeling (FCC, CE, etc.)"
    ],
    "compliance": [
      "Ensure RoHS compliance (lead-free soldering)",
      "Coordinate CE/FCC certifications",
      "Track component country of origin for compliance",
      "Handle REACH, Prop 65 requirements"
    ]
  },
  "metrics": {
    "tracks": [
      "production-yield-percentage",
      "assembly-time-per-unit",
      "defect-rate-per-batch",
      "component-lead-time",
      "production-cost-per-unit"
    ],
    "targets": {
      "yield": ">98%",
      "assembly-time": "<15 minutes per device",
      "defect-rate": "<2%",
      "cost-per-unit": "[target based on volumes]"
    }
  },
  "memory": {
    "persists": [
      "supplier-quality-issues",
      "assembly-process-improvements",
      "defect-root-cause-analyses",
      "component-obsolescence-handling"
    ],
    "queries": [
      "past-supplier-performance",
      "similar-defect-patterns",
      "proven-assembly-techniques"
    ]
  }
}
